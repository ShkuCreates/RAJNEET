generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String?   @unique
  emailVerified       DateTime?
  image               String?
  avatar_url          String?
  role                String    @default("CITIZEN") // CITIZEN, ADMIN
  state               String?
  district            String?
  category            String?   // Added for new onboarding
  mobile              String?   // Added for new onboarding
  onboarding_complete Boolean   @default(false)
  bio                 String?   @db.Text
  username            String?   @unique
  created_at          DateTime  @default(now())

  accounts   Account[]
  sessions   Session[]
  news       News[]
  opinions   Opinion[]
  pollVotes  PollVote[]
  polls      Poll[]
  mpLetters  MpLetter[]
}

model News {
  id              String   @id @default(cuid())
  headline        String
  summary         String   @db.Text
  body            String   @db.Text
  source_url      String?
  cover_image_url String?
  category        String   // POLITICAL, CRIMINAL, FINANCE, CORPORATE, INFRASTRUCTURE, SOCIAL, ENVIRONMENT, HEALTH, EDUCATION, INTERNATIONAL
  geo_level       String   // DISTRICT, STATE, NATIONAL, INTERNATIONAL
  state           String?
  district        String?
  status          String   @default("DRAFT") // DRAFT, PUBLISHED
  posted_by       String
  created_at      DateTime @default(now())

  // SEO Fields
  seo_title       String?
  meta_description String?
  slug            String?  @unique
  focus_keywords  String[]
  schema_markup   String?  @db.Text
  seo_body        String?  @db.Text
  seo_score       Int      @default(0)
  primary_keyword String?
  is_trending     Boolean  @default(false)
  priority        String   @default("normal") // normal, high

  author     User       @relation(fields: [posted_by], references: [id])
  opinions   Opinion[]
  polls      Poll[]
  mpLetters  MpLetter[]
}

model Opinion {
  id         String   @id @default(cuid())
  news_id    String
  user_id    String
  stance     String   // FOR, AGAINST, NEUTRAL
  comment    String   @db.Text
  tag        String   // FACT, OPINION, ALLEGATION, SATIRE
  upvotes    Int      @default(0)
  downvotes  Int      @default(0)
  parent_id  String?
  created_at DateTime @default(now())

  news       News      @relation(fields: [news_id], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [user_id], references: [id])
  parent     Opinion?  @relation("Thread", fields: [parent_id], references: [id])
  replies    Opinion[] @relation("Thread")
}

model Poll {
  id         String    @id @default(cuid())
  question   String
  options    Json      // Array of strings or objects representing options
  news_id    String?
  geo_scope  String    // DISTRICT, STATE, NATIONAL
  state      String?
  district   String?
  expires_at DateTime
  created_by String
  created_at DateTime  @default(now())

  news       News?      @relation(fields: [news_id], references: [id])
  creator    User       @relation(fields: [created_by], references: [id])
  votes      PollVote[]
}

model PollVote {
  id             String   @id @default(cuid())
  poll_id        String
  user_id        String
  selected_option String
  created_at     DateTime @default(now())

  poll       Poll @relation(fields: [poll_id], references: [id], onDelete: Cascade)
  user       User @relation(fields: [user_id], references: [id])

  @@unique([poll_id, user_id]) // One vote per user per poll
}

model MpLetter {
  id         String   @id @default(cuid())
  news_id    String
  user_id    String
  subject    String
  body       String   @db.Text
  district   String
  status     String   @default("NO_RESPONSE") // NO_RESPONSE, RESPONDED
  created_at DateTime @default(now())

  news       News @relation(fields: [news_id], references: [id])
  user       User @relation(fields: [user_id], references: [id])
}

model Bill {
  id                String   @id @default(cuid())
  title             String
  ministry          String
  status            String   // INTRODUCED, COMMITTEE, PASSED, REJECTED
  lok_sabha_votes   Json?
  rajya_sabha_votes Json?
  created_at        DateTime @default(now())
}

model TrendsCache {
  keyword    String   @id
  result     Json
  fetched_at DateTime @default(now())
}
