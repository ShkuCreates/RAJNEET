generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String?   @unique
  emailVerified       DateTime?
  image               String?
  avatar_url          String?
  role                String    @default("CITIZEN") // CITIZEN, ADMIN
  state               String?
  district            String?
  category            String?   // Added for new onboarding
  mobile              String?   // Added for new onboarding
  onboarding_complete Boolean   @default(false)
  bio                 String?   @db.Text
  username            String?   @unique
  reputation_score    Int       @default(100)
  reputation_tier     String    @default("Citizen") // Citizen, Active Citizen, Voice of the People, Community Leader, Political Analyst, RAJNEET Legend
  upi_id              String?
  reading_streak      Int       @default(0)
  last_read_date      DateTime?
  created_at          DateTime  @default(now())

  accounts   Account[]
  sessions   Session[]
  news       News[]
  opinions   Opinion[]
  pollVotes  PollVote[]
  polls      Poll[]
  mpLetters  MpLetter[]
  newsUpvotes NewsUpvote[]
  pageViews   PageView[]
  articles   Article[]
  reputationEvents ReputationEvent[]
  debateParticipants DebateParticipant[]
  juryVotes JuryVote[]
  debateNotificationSubscriber DebateNotificationSubscriber[]
}

model News {
  id              String   @id @default(cuid())
  headline        String
  summary         String   @db.Text
  body            String   @db.Text
  source_url      String?
  cover_image_url String?
  category        String   // POLITICAL, CRIMINAL, FINANCE, CORPORATE, INFRASTRUCTURE, SOCIAL, ENVIRONMENT, HEALTH, EDUCATION, INTERNATIONAL
  geo_level       String   // DISTRICT, STATE, NATIONAL, INTERNATIONAL
  state           String?
  district        String?
  status          String   @default("DRAFT") // DRAFT, PUBLISHED
  posted_by       String
  created_at      DateTime @default(now())

  // SEO Fields
  seo_title       String?
  meta_description String?
  slug            String?  @unique
  focus_keywords  String[]
  schema_markup   String?  @db.Text
  seo_body        String?  @db.Text
  seo_score       Int      @default(0)
  primary_keyword String?
  is_trending     Boolean  @default(false)
  priority        String   @default("normal") // normal, high

  author     User       @relation(fields: [posted_by], references: [id])
  opinions   Opinion[]
  polls      Poll[]
  mpLetters  MpLetter[]
  upvotes    NewsUpvote[]
  pageViews  PageView[]
}

model Opinion {
  id               String   @id @default(cuid())
  news_id          String
  user_id          String
  username         String?
  stance           String   // FOR, AGAINST, NEUTRAL
  comment          String   @db.Text
  tag              String   // FACT, OPINION, ALLEGATION, SATIRE
  like_count       Int      @default(0)
  upvotes          Int      @default(0)
  downvotes        Int      @default(0)
  insightful_count Int      @default(0)
  biased_count     Int      @default(0)
  misleading_count Int      @default(0)
  parent_id        String?
  hashtags         String[]
  is_fact_checked  Boolean  @default(false)
  created_at       DateTime @default(now())

  news       News      @relation(fields: [news_id], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [user_id], references: [id])
  parent     Opinion?  @relation("Thread", fields: [parent_id], references: [id])
  replies    Opinion[] @relation("Thread")
}

model Poll {
  id         String    @id @default(cuid())
  question   String
  options    Json      // Array of strings or objects representing options
  news_id    String?
  geo_scope  String    // DISTRICT, STATE, NATIONAL
  state      String?
  district   String?
  expires_at DateTime
  created_by String
  created_at DateTime  @default(now())

  news       News?      @relation(fields: [news_id], references: [id])
  creator    User       @relation(fields: [created_by], references: [id])
  votes      PollVote[]
}

model PollVote {
  id             String   @id @default(cuid())
  poll_id        String
  user_id        String
  selected_option String
  created_at     DateTime @default(now())

  poll       Poll @relation(fields: [poll_id], references: [id], onDelete: Cascade)
  user       User @relation(fields: [user_id], references: [id])

  @@unique([poll_id, user_id]) // One vote per user per poll
}

model MpLetter {
  id         String   @id @default(cuid())
  news_id    String
  user_id    String
  subject    String
  body       String   @db.Text
  district   String
  status     String   @default("NO_RESPONSE") // NO_RESPONSE, RESPONDED
  created_at DateTime @default(now())

  news       News @relation(fields: [news_id], references: [id])
  user       User @relation(fields: [user_id], references: [id])
}

model Bill {
  id                String   @id @default(cuid())
  title             String
  ministry          String
  status            String   // INTRODUCED, COMMITTEE, PASSED, REJECTED
  lok_sabha_votes   Json?
  rajya_sabha_votes Json?
  created_at        DateTime @default(now())
}

model NewsUpvote {
  id         String   @id @default(cuid())
  news_id    String
  user_id    String
  created_at DateTime @default(now())

  news       News @relation(fields: [news_id], references: [id], onDelete: Cascade)
  user       User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([news_id, user_id])
}

model PageView {
  id         String   @id @default(cuid())
  news_id    String?
  path       String
  user_id    String?
  ip         String?
  created_at DateTime @default(now())

  news       News? @relation(fields: [news_id], references: [id], onDelete: Cascade)
  user       User? @relation(fields: [user_id], references: [id], onDelete: SetNull)
}

model TrendsCache {
  keyword    String   @id
  result     Json
  fetched_at DateTime @default(now())
}

model Article {
  id              String   @id @default(cuid())
  title           String
  body            String   @db.Text
  excerpt         String?  @db.Text
  cover_image_url String?
  author_id       String
  author_username String
  tags            String[]
  status          String   @default("pending_review") // pending_review, approved, rejected
  is_featured     Boolean  @default(false)
  is_verified     Boolean  @default(false)
  view_count      Int      @default(0)
  upvote_count    Int      @default(0)
  word_count      Int      @default(0)
  read_time_minutes Int    @default(0)
  slug            String?  @unique
  source_urls     String[]
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  author          User     @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([author_username])
  @@index([slug])
}

model ReputationEvent {
  id            String   @id @default(cuid())
  user_id       String
  event_type    String
  points_change Int
  reference_id  String?
  created_at    DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([event_type])
}

model Debate {
  id               String   @id @default(cuid())
  topic            String
  description      String?  @db.Text
  created_by       String
  status           String   @default("upcoming") // upcoming, live, completed
  scheduled_at     DateTime?
  ends_at          DateTime?
  winner_side      String?
  participant_count Int      @default(0)
  created_at       DateTime @default(now())

  arguments DebateArgument[]
  participants DebateParticipant[]
  juryVotes JuryVote[]
}

model DebateArgument {
  id          String   @id @default(cuid())
  debate_id   String
  user_id     String
  username    String
  side        String   // FOR, AGAINST
  content     String   @db.Text
  like_count  Int      @default(0)
  jury_score  Decimal  @default(0)
  created_at  DateTime @default(now())

  debate Debate @relation(fields: [debate_id], references: [id], onDelete: Cascade)
  juryVotes JuryVote[]
}

model DebateParticipant {
  id        String   @id @default(cuid())
  debate_id String
  user_id   String
  side      String   // FOR, AGAINST
  joined_at DateTime @default(now())

  debate Debate @relation(fields: [debate_id], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([debate_id, user_id])
}

model JuryVote {
  id            String   @id @default(cuid())
  debate_id     String
  juror_id      String
  argument_id   String
  logic_score   Int?
  evidence_score Int?
  clarity_score Int?
  created_at    DateTime @default(now())

  debate   Debate         @relation(fields: [debate_id], references: [id], onDelete: Cascade)
  argument DebateArgument @relation(fields: [argument_id], references: [id], onDelete: Cascade)
  juror    User           @relation(fields: [juror_id], references: [id], onDelete: Cascade)

  @@unique([debate_id, juror_id, argument_id])
}

model DebateNotificationSubscriber {
  id                 String   @id @default(cuid())
  user_id            String
  email              String
  topic_preferences  String[]
  is_active          Boolean  @default(true)
  subscribed_at      DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id])
}
